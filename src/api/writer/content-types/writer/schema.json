{
  "kind": "collectionType",
  "collectionName": "writers",
  "info": {
    "singularName": "writer",
    "pluralName": "writers",
    "displayName": "Escritores"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "fullName"
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "speciality": {
      "type": "string",
      "required": true
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "longDescription": {
      "type": "blocks",
      "required": true
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-article.blog-article",
      "mappedBy": "writer"
    }
  }
}
