{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimony",
    "pluralName": "testimonials",
    "displayName": "Testimonios"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "type": "string",
      "maxLength": 80,
      "required": true
    },
    "role": {
      "type": "string",
      "maxLength": 100
    },
    "location": {
      "type": "string",
      "maxLength": 80
    },
    "testimonial": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "testimonial"
    }
  }
}
