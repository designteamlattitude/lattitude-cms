{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Productos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 120,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 120,
      "required": true
    },
    "description": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "price": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "MXN"
    },
    "sku": {
      "type": "string",
      "maxLength": 25
    },
    "isNew": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "documents": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "files"
      ]
    },
    "benefit": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-benefit.purchase-benefit"
    },
    "faqItem": {
      "type": "component",
      "component": "product.faq-item",
      "repeatable": true
    },
    "technicalSheet": {
      "type": "component",
      "component": "product.technical-sheet",
      "repeatable": true
    },
    "technicalSpecifications": {
      "type": "component",
      "component": "product.technical-specifications",
      "repeatable": true
    },
    "relatedConsumables": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "variants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "subcategories": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subcategory.subcategory",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    }
  }
}
