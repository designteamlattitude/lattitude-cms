    "name": {
      "type": "string",
      "maxLength": 60,
      "required": true
    },
    "url": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "icon": {
      "type": "enumeration",
      "enum": [
        "facebook",
        "instagram",
        "linkedin",
        "x",
        "youtube",
        "tiktok",
        "whatsapp"
      ]
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  },
  "config": {}
}
